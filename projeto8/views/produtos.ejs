<%- include("partials/header") %>
    <section class="header-pagina-interna">
        <div class="container">
            <h2>Produtos</h2>
        </div>
    </section>
    <section class="py-3 border-bottom">
        <div class="container" id="botoes-categorias">
            <a class="btn btn-outline-secondary" onclick="mostrarTodosOsProdutos()">Todos</a>
            <% categorias.forEach(categoria=> { %>
                            <a class="btn btn-outline-secondary" onclick="mostrarProdutosPorCategoria(<%= categoria.idCategoria %>)">
                                <%= categoria.nome %>
                            </a>
                        <% }) %>
        </div>
    </section>
    <section class="produtos py-5">
        <div id="lista-produtos" class="container d-lg-flex flex-wrap column-gap-3 py-5">

            <% produtos.forEach(produto=> { %>
                <div class="card p-2 w-lg-25" data-categoria="<%= produto.idCategoria %>">
                    <div class="imagem d-flex align-items-center justify-content-center">
                        <img src="/assets/img/<%= produto.imagem %>" alt="<%= produto.nome %>" class="img-fluid">
                    </div>
                    <h3 class="text-uppercase mt-1">
                        <%= produto.nome %>
                    </h3>
                    <p class="mb-1 mt-1">
                        Descrição...
                    </p>
                    <div class="d-flex justify-content-between">
                        <span>
                            R$
                            <span class="text-success">
                                <!-- <%= Number(produto.preco).toFixed(2).replace('.',',') %> -->
                                <%=  new Intl.NumberFormat('pt-BR', {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                }).format(produto.preco); %>
                            </span>
                        </span>
                        <a onclick="adicionarProdutoAoCarrinho('<%= produto.idProduto %>', '<%= produto.nome %>', '<%= produto.imagem %>', '<%= produto.preco %>')"
                            class="btn1">
                            <i class="fa-solid fa-plus"></i>
                        </a>
                    </div>
                </div>
                <% }) %>

        </div>
    </section>
    <script src="/assets/js/produtos.js"></script>
    <%- include("partials/footer") %>